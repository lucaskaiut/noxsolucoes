# Analytics — habilite apenas os providers desejados.
# Flags aceitam "true" ou "1". Provider sem ID configurado não é registrado.

# Logs detalhados no console do navegador
NEXT_PUBLIC_ANALYTICS_DEBUG=false

# Google Analytics 4
NEXT_PUBLIC_ANALYTICS_GA4=false
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Meta Pixel
NEXT_PUBLIC_ANALYTICS_META_PIXEL=false
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag
NEXT_PUBLIC_ANALYTICS_LINKEDIN=false
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
NEXT_PUBLIC_LINKEDIN_CONVERSION_ID_LEAD=

# Microsoft Clarity
NEXT_PUBLIC_ANALYTICS_CLARITY=false
NEXT_PUBLIC_CLARITY_PROJECT_ID=
